<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codex.mission-control.qa-integration</string>

  <key>ProgramArguments</key>
  <array>
    <string>__NODE_PATH__</string>
    <string>__MISSION_CONTROL_REPO__/src/mission-control-qa-integration.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__MISSION_CONTROL_REPO__</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>StandardOutPath</key>
  <string>__LOG_DIR__/qa-integration.log</string>

  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/qa-integration.err.log</string>
</dict>
</plist>
