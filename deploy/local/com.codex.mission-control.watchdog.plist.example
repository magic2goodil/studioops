<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codex.mission-control.watchdog</string>

  <key>ProgramArguments</key>
  <array>
    <string>__NODE_PATH__</string>
    <string>__MISSION_CONTROL_RUNTIME__/src/mission-control-watchdog.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__MISSION_CONTROL_REPO__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>ProcessType</key>
  <string>Background</string>

  <key>StandardOutPath</key>
  <string>__LOG_DIR__/watchdog.log</string>

  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/watchdog.err.log</string>
</dict>
</plist>
